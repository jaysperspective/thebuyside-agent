# --- thebuyside-agent: example environment ---
# Copy to `.env` and fill in real values. The `.env` file is gitignored.

# Base-mainnet wallet private key, used by the gateway to sign x402 payments.
# Hex-encoded, 0x-prefixed. Use a FRESH wallet you fund with a small amount of
# USDC on Base — do not reuse a key with significant funds. See README for setup.
X402_PAYER_PRIVATE_KEY=0xPASTE_YOUR_PRIVATE_KEY_HERE

# Optional: override the M0 demo target URL. Defaults to news-ep stories search.
# X402_TEST_URL=https://news-ep.com/api/v1/stories?market=dmv&limit=1
