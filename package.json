{
  "name": "thebuyside-x402-agent",
  "version": "0.4.1",
  "description": "Buyer-side x402 MCP gateway — let any agent pay any x402 API without seeing a 402 or a wallet.",
  "license": "Apache-2.0",
  "author": "Joshua Harrington",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "thebuyside-x402-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "x402",
    "mcp",
    "model-context-protocol",
    "crypto-payments",
    "agents",
    "usdc",
    "base",
    "stablecoin",
    "agent-payments"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaysperspective/thebuyside-x402-agent.git"
  },
  "homepage": "https://github.com/jaysperspective/thebuyside-x402-agent#readme",
  "bugs": {
    "url": "https://github.com/jaysperspective/thebuyside-x402-agent/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "start": "tsx src/index.ts",
    "smoke": "tsx scripts/mcp-smoke.ts",
    "test": "vitest run",
    "pay-newsep": "tsx scripts/pay-newsep.ts",
    "pay-solana": "tsx scripts/pay-solana.ts",
    "verify-seed": "tsx scripts/verify-seed.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "viem": "^2.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
